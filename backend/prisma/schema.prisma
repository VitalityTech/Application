generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Події, які створив цей користувач (Organizer)
  organizedEvents Event[] @relation("Organizer")

  // Події, до яких користувач приєднався (Participants)
  joinedEvents Event[] @relation("EventParticipants")
}

model Event {
  id          String          @id @default(uuid())
  title       String
  category    String          @default("Інше")
  description String?
  location    String?
  capacity    Int?
  visibility  EventVisibility @default(PUBLIC)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Організатор події
  organizer User?   @relation("Organizer", fields: [userId], references: [id])
  userId    String?

  // Список учасників (Many-to-Many)
  participants User[] @relation("EventParticipants")

  tags Tag[] @relation("EventTags")
}

model Tag {
id        String   @id @default(uuid())
name      String   @unique // Назва тегу має бути унікальною за ТЗ

// Зв'язок Many-to-Many з подіями
events    Event[]  @relation("EventTags")
}